# Notion MCP (https://www.notion.so/profile/integrations 에서 Internal Integration 생성)
export NOTION_TOKEN=""

# Cloudflare API Token (for Terraform)
export TF_VAR_cloudflare_api_token=""

# Default IP for A records (dynamic IP)
export TF_VAR_default_ip=""

# Telegram MCP (bot token from @BotFather)
export TELEGRAM_BOT_TOKEN=""
export TELEGRAM_CHAT_ID=""

# Kubernetes MCP
export KUBECONFIG="$HOME/.kube/config"

# AWS MCP
export AWS_PROFILE="homelab"
export AWS_REGION="ap-northeast-2"

# GitHub MCP (gh CLI 토큰 재활용, gh auth login 필요)
export GITHUB_PERSONAL_ACCESS_TOKEN="$(gh auth token)"
