# Terraform variables
export TF_VAR_cloudflare_account_id="d99bb67d7bf0e7355a4e5e92c75904ee"
export TF_VAR_zone_name="json-server.win"
export AWS_PROFILE="homelab"

# Load secrets from .envrc.local (gitignored)
source_env_if_exists .envrc.local

export KUBECONFIG=~/.kube/config-json

# Go bin (mcp-grafana 등 `go install` 바이너리용)
PATH_add ~/go/bin
